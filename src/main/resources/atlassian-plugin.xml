<?xml version="1.0" encoding="UTF-8"?>
<atlassian-plugin key="${atlassian.plugin.key}" name="${project.name}" plugins-version="2">
  <plugin-info>
    <description>${project.description}</description>
    <version>${project.version}</version>
    <vendor name="junsik" url="https://github.com/junsik/md-share-confluence"/>
  </plugin-info>

  <resource type="i18n" name="i18n" location="mdshare"/>

  <component-import key="attachmentManager" interface="com.atlassian.confluence.pages.AttachmentManager"/>
  <component-import key="pageBuilderService" interface="com.atlassian.webresource.api.assembler.PageBuilderService"/>
  <component-import key="settingsManager" interface="com.atlassian.confluence.setup.settings.SettingsManager"/>

  <!-- mermaid → PNG (Kroki 위임). PDF/Word export 가 fetch 하는 same-origin 이미지 URL. -->
  <servlet name="md-share mermaid image" key="md-share-mermaid-image"
           class="io.github.junsik.mdshare.confluence.MermaidImageServlet">
    <url-pattern>/md-share/mermaid/*</url-pattern>
  </servlet>
  <component-import key="whitelistService" interface="com.atlassian.plugins.whitelist.WhitelistService"/>
  <component-import key="outboundWhitelist" interface="com.atlassian.plugins.whitelist.OutboundWhitelist"/>

  <web-resource key="md-share-styles" name="md-share styles">
    <resource type="download" name="md-share.css" location="/css/md-share.css"/>
    <context>viewcontent</context>
    <context>preview</context>
  </web-resource>

  <!-- mermaid 번들(2.7MB)은 context 로드가 아니라 매크로가 mermaid 블록을 렌더링할 때만
       PageBuilderService.requireWebResource 로 요구된다. 리소스 순서 중요: AMD 가드 → mermaid → init. -->
  <web-resource key="md-share-mermaid" name="md-share mermaid renderer">
    <resource type="download" name="md-share-amd-guard.js" location="/js/md-share-amd-guard.js"/>
    <resource type="download" name="mermaid.min.js" location="/js/mermaid.min.js"/>
    <resource type="download" name="md-share-mermaid.js" location="/js/md-share-mermaid.js"/>
  </web-resource>

  <web-resource key="md-share-macro-browser" name="md-share macro browser field">
    <resource type="download" name="md-share-macro-browser.js" location="/js/md-share-macro-browser.js"/>
    <dependency>com.atlassian.confluence.editor:macro-browser-js</dependency>
    <context>macro-browser</context>
  </web-resource>

  <xhtml-macro name="md-share" class="io.github.junsik.mdshare.confluence.MarkdownMacro" key="md-share-macro">
    <description key="io.github.junsik.md-share-confluence.md-share.desc"/>
    <category name="formatting"/>
    <category name="external-content"/>
    <alias name="markdown"/>
    <parameters>
      <!-- type="attachment" 피커는 드롭다운이 비는 알려진 Confluence 버그(CONFSERVER-24016)가
           있어 string 으로 받는다. 파일명이 틀리면 매크로가 페이지의 md 첨부 목록을 보여준다. -->
      <parameter name="attachment" type="string"/>
      <parameter name="url" type="string"/>
    </parameters>
  </xhtml-macro>
</atlassian-plugin>
